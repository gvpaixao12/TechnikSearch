# ===== Core =====
GROQ_API_KEY=cole_aqui_a_chave_do_console_groq
PORT=3001

# ===== Imagens dos carros =====
# Chave Groq separada para o validador vision (opcional).
# Se vazia, cai no GROQ_API_KEY. Recomendado ter separada para
# poder revogar a feature de imagens isoladamente.
GROQ_VISION_API_KEY=

# Serper.dev — busca de imagens (fallback quando Wikimedia Commons não tem).
# Free tier: 2.500 buscas one-time no signup, sem cartão.
# https://serper.dev/api-key
SERPER_API_KEY=

# Supabase — armazena fotos validadas no bucket "car-images"
# e o índice na tabela "car_images_cache".
# Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# service_role key — SOMENTE backend, bypassa RLS, nunca expor no frontend
SUPABASE_SERVICE_KEY=
